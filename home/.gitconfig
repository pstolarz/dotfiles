[user]
	name = Piotr Stolarz
[push]
	default = simple
[alias]
	br = branch
	bra = branch -avv
	ci = commit
	co = checkout
    di = diff
	fsr = fsck --no-reflog
	gca = gc --prune=all
	gcaa = gc --prune=all --aggressive
	lg = log --oneline --decorate --graph
	lso = ls-files -o
	reh = reset --hard
	rfc = reflog expire --expire=now --all
	sm = submodule
	smu = submodule update --init --recursive
	st = status
